# =============================================================================
# MediCare — Environment Configuration Template
# Copy this file to .env and fill in your own credentials.
#   cp .env.example .env
# =============================================================================

# aiXplain API
TEAM_API_KEY=
AIXPLAIN_AGENT_ID=
AIXPLAIN_PIPELINE_ID=

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=Medicare

# Flask
PORT=5000
FLASK_DEBUG=true

# SMTP / Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_USE_TLS=true
MAIL_DEBUG=false
